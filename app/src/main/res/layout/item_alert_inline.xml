<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:paddingLeft="4dp"
    android:paddingRight="4dp">

    <ImageView
        android:id="@+id/ivAlertIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_intruder"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/tvAlertLabel"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:text="Unknown Person"
        android:textColor="@color/iris_text_primary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvAlertTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2m ago"
        android:textColor="@color/iris_text_secondary"
        android:textSize="12sp" />

</LinearLayout>
