<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iris_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_iris_eye"
            android:tint="@color/iris_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setup_title"
            android:textColor="@color/iris_text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/iris_text_secondary"
            android:textSize="14sp" />

        <!-- Section: Device -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="ESP32-S3 DEVICE"
            android:textColor="@color/iris_accent"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDeviceIp"
            style="@style/Widget.IRIS.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/hint_device_ip">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDeviceIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="@color/iris_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDeviceId"
            style="@style/Widget.IRIS.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="@string/hint_device_id">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDeviceId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/iris_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Section: MQTT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="MQTT BROKER"
            android:textColor="@color/iris_accent"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMqttBroker"
            style="@style/Widget.IRIS.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/hint_mqtt_broker">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttBroker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="@color/iris_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMqttPort"
            style="@style/Widget.IRIS.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/hint_mqtt_port">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1883"
                android:textColor="@color/iris_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMqttUser"
            style="@style/Widget.IRIS.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/hint_mqtt_user">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/iris_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMqttPassword"
            style="@style/Widget.IRIS.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="@string/hint_mqtt_password"
            app:endIconMode="password_toggle">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/iris_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestConnection"
            style="@style/Widget.IRIS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:text="@string/btn_test_connection" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.IRIS.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="32dp"
            android:text="@string/btn_save_config" />

    </LinearLayout>
</ScrollView>
