<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Stream ImageView -->
    <ImageView
        android:id="@+id/ivStream"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:background="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Loading overlay -->
    <ProgressBar
        android:id="@+id/progressLoading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/iris_accent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/gradient_top"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bottom gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/gradient_bottom"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Top controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_btn"
            android:tint="@color/white"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvStreamStatus"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Connecting…"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingLeft="32dp" android:paddingRight="32dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Flashlight -->
        <ImageButton
            android:id="@+id/btnFlashlight"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="32dp"
            android:src="@drawable/ic_flashlight"
            android:background="@drawable/bg_icon_btn"
            android:tint="@color/white"
            android:contentDescription="Toggle flashlight" />

        <!-- Capture -->
        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_camera"
            android:background="@drawable/bg_capture_btn"
            android:tint="@color/iris_primary"
            android:contentDescription="Capture frame" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
