<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iris_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Settings"
            android:textColor="@color/iris_text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium" />

        <!-- Section: Notifications -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="NOTIFICATIONS"
            android:textColor="@color/iris_accent"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.IRIS.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Intruder alerts toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp" android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_alerts_enabled"
                        android:textColor="@color/iris_text_primary"
                        android:textSize="15sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAlerts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/iris_divider" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                <!-- Motion alerts toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp" android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_motion_alerts"
                        android:textColor="@color/iris_text_primary"
                        android:textSize="15sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchMotion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/iris_divider" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                <!-- Sound toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp" android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_sound"
                        android:textColor="@color/iris_text_primary"
                        android:textSize="15sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/iris_divider" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                <!-- Vibration toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp" android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_vibration"
                        android:textColor="@color/iris_text_primary"
                        android:textSize="15sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchVibration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section: Device Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="DEVICE"
            android:textColor="@color/iris_accent"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.IRIS.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Device ID -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Device ID"
                        android:textColor="@color/iris_text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvDeviceId"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="iris_01" android:textColor="@color/iris_text_primary" android:textSize="13sp" />
                </LinearLayout>

                <!-- Device IP -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Device IP"
                        android:textColor="@color/iris_text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvDeviceIp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/iris_text_primary" android:textSize="13sp" />
                </LinearLayout>

                <!-- MQTT Broker -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="MQTT Broker"
                        android:textColor="@color/iris_text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvMqttBroker"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/iris_text_primary" android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Device actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditConfig"
            style="@style/Widget.IRIS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_edit_config" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReconnect"
            style="@style/Widget.IRIS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_reconnect" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRebootDevice"
            style="@style/Widget.IRIS.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_reboot" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearAlerts"
            style="@style/Widget.IRIS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="32dp"
            android:text="@string/btn_clear_alerts" />

        <!-- About -->
        <TextView
            android:id="@+id/tvAppVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="IRIS v1.0.0"
            android:textColor="@color/iris_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Northwest Samar State University"
            android:textColor="@color/iris_text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
