<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.IRIS.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Image -->
        <ImageView
            android:id="@+id/ivCapture"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_placeholder"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Saved badge overlay -->
        <TextView
            android:id="@+id/tvSavedBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="6dp"
            android:text=" ✓ Saved "
            android:textColor="@color/iris_primary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_badge_saved"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@+id/ivCapture"
            app:layout_constraintStart_toStartOf="@+id/ivCapture" />

        <!-- Bottom info bar -->
        <LinearLayout
            android:id="@+id/infoBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            app:layout_constraintTop_toBottomOf="@+id/ivCapture">

            <TextView
                android:id="@+id/tvImageLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unknown Person"
                android:textColor="@color/iris_text_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvImageTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jun 9 • 14:32"
                android:textColor="@color/iris_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@+id/infoBar">

            <!-- Download button -->
            <ImageButton
                android:id="@+id/btnDownload"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_download"
                android:background="@drawable/bg_action_btn_accent"
                android:tint="@color/iris_primary"
                android:contentDescription="Download image"
                android:scaleType="center" />

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/bg_action_btn_danger"
                android:tint="@color/white"
                android:contentDescription="Delete image"
                android:scaleType="center" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
