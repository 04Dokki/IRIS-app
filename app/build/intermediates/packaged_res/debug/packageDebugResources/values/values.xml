    <style name="TextAppearance.IRIS.Accent" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/iris_accent</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.IRIS.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/iris_text_secondary</item>
    </style>
    <style name="TextAppearance.IRIS.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/iris_text_secondary</item>
    </style>
    <style name="TextAppearance.IRIS.Display" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/iris_text_primary</item>
    </style>
    <style name="TextAppearance.IRIS.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/iris_text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>
    <style name="Theme.IRIS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/iris_accent</item>
        <item name="colorPrimaryVariant">@color/iris_accent_dim</item>
        <item name="colorOnPrimary">@color/iris_primary</item>
        <item name="colorSecondary">@color/iris_accent</item>
        <item name="colorSurface">@color/iris_surface</item>
        <item name="colorOnSurface">@color/iris_text_primary</item>
        <item name="android:colorBackground">@color/iris_primary</item>
        <item name="android:windowBackground">@color/iris_primary</item>
        <item name="android:statusBarColor">@color/iris_primary</item>
        <item name="android:navigationBarColor">@color/iris_surface</item>
        <item name="android:textColorPrimary">@color/iris_text_primary</item>
        <item name="android:textColorSecondary">@color/iris_text_secondary</item>
        <item name="materialButtonStyle">@style/Widget.IRIS.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.IRIS.BottomNavigation</item>
        <item name="chipStyle">@style/Widget.IRIS.Chip</item>
        <item name="textInputStyle">@style/Widget.IRIS.TextInput</item>
    </style>
    <style name="Theme.IRIS.Immersive" parent="Theme.IRIS">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="Theme.IRIS.Splash" parent="Theme.IRIS">
        <item name="android:windowBackground">@color/iris_primary</item>
        <item name="android:statusBarColor">@color/iris_primary</item>
        <item name="android:navigationBarColor">@color/iris_primary</item>
    </style>
    <style name="Widget.IRIS.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/iris_surface</item>
        <item name="itemTextColor">@color/iris_nav_selector</item>
        <item name="itemIconTint">@color/iris_nav_selector</item>
        <item name="elevation">8dp</item>
    </style>
    <style name="Widget.IRIS.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/iris_accent</item>
        <item name="android:textColor">@color/iris_primary</item>
        <item name="rippleColor">@color/iris_ripple</item>
    </style>
    <style name="Widget.IRIS.Button.Danger" parent="Widget.IRIS.Button">
        <item name="backgroundTint">@color/iris_danger</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="Widget.IRIS.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/iris_accent</item>
        <item name="android:textColor">@color/iris_accent</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="Widget.IRIS.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/iris_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/iris_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="Widget.IRIS.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textColor">@color/iris_primary</item>
        <item name="chipCornerRadius">4dp</item>
    </style>
    <style name="Widget.IRIS.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/iris_accent</item>
        <item name="hintTextColor">@color/iris_text_secondary</item>
        <item name="android:textColorHint">@color/iris_text_secondary</item>
    </style>
</resources>